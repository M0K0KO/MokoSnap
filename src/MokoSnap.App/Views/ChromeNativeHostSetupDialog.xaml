<Window x:Class="MokoSnap.App.Views.ChromeNativeHostSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chrome Capture Setup"
        Height="560"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    IsCancel="True"
                    MinWidth="88" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Extension ID"
                               Margin="0,0,12,10"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Text="{Binding ExtensionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Native host exe"
                               Margin="0,0,12,10" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding NativeHostExePath}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Manifest path"
                               Margin="0,0,12,10" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding ManifestPath}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Registry"
                               Margin="0,0,12,10" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Text="{Binding RegistryStatus}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Latest capture"
                               Margin="0,0,12,0" />
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Text="{Binding LatestCaptureStatus}"
                             IsReadOnly="True"
                             TextWrapping="Wrap" />
                </Grid>

                <WrapPanel Margin="0,16,0,12">
                    <Button Content="Check Status"
                            Command="{Binding CheckStatusCommand}"
                            MinWidth="104"
                            Margin="0,0,8,8" />
                    <Button Content="Register Native Host"
                            Command="{Binding RegisterNativeHostCommand}"
                            MinWidth="144"
                            Margin="0,0,8,8" />
                    <Button Content="Open Chrome Extensions Page"
                            Command="{Binding OpenChromeExtensionsCommand}"
                            MinWidth="184"
                            Margin="0,0,8,8" />
                    <Button Content="Open Extension Folder"
                            Command="{Binding OpenExtensionFolderCommand}"
                            MinWidth="152"
                            Margin="0,0,8,8" />
                    <Button Content="Open Latest Capture File"
                            Command="{Binding OpenLatestCaptureFileCommand}"
                            MinWidth="168"
                            Margin="0,0,8,8" />
                </WrapPanel>

                <TextBlock Text="Diagnostics"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBox Text="{Binding DiagnosticsText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         MinHeight="190"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
