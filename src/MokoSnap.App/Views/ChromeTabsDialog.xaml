<Window x:Class="MokoSnap.App.Views.ChromeTabsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Chrome Tabs"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBlock Text="Captured:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBlock Text="{Binding CapturedAt}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />
            <Button Content="Select All"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    Click="OnSelectAllClicked" />
            <Button Content="Deselect All"
                    MinWidth="96"
                    Click="OnDeselectAllClicked" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Import Selected"
                    IsDefault="True"
                    MinWidth="112"
                    Margin="0,0,8,0"
                    Click="OnImportSelectedClicked" />
            <Button Content="Cancel"
                    IsCancel="True"
                    MinWidth="88" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Windows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Header}"
                                  IsExpanded="True"
                                  Margin="0,0,0,10">
                            <DataGrid ItemsSource="{Binding Tabs}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="False"
                                      MinHeight="120">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Import"
                                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Title"
                                                        Binding="{Binding Title}"
                                                        IsReadOnly="True"
                                                        Width="2*" />
                                    <DataGridTextColumn Header="URL"
                                                        Binding="{Binding Url}"
                                                        IsReadOnly="True"
                                                        Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
