<Window x:Class="MokoSnap.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        MinHeight="560"
        MinWidth="620"
        Height="620"
        Width="680"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Save"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnSaveClicked" />
            <Button Content="Cancel"
                    MinWidth="88"
                    IsCancel="True" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="General"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <CheckBox Content="Minimize to tray"
                          IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"
                          Margin="0,0,0,8" />
                <CheckBox Content="Start minimized to tray"
                          IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}"
                          Margin="0,0,0,18" />

                <Separator Margin="0,0,0,16" />

                <TextBlock Text="Hotkeys"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="96" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Quick Switcher"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBox x:Name="QuickSwitcherHotkeyBox"
                             Grid.Column="1"
                             Text="{Binding QuickSwitcherHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="OnHotkeyTextBoxPreviewKeyDown"
                             Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="Reset"
                            Command="{Binding ResetQuickSwitcherHotkeyCommand}" />
                </Grid>
                <TextBox Text="{Binding HotkeyValidationText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,18" />

                <Separator Margin="0,0,0,16" />

                <TextBlock Text="Startup / Tray"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <CheckBox Content="Launch MokoSnap when Windows starts"
                          IsChecked="{Binding LaunchOnStartup, Mode=TwoWay}"
                          Margin="0,0,0,10" />
                <TextBox Text="{Binding StartupStatusText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="56"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,18" />

                <Separator Margin="0,0,0,16" />

                <TextBlock Text="Chrome Capture"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <TextBox Text="{Binding ChromeCaptureStatusText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="64"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10" />
                <WrapPanel>
                    <Button Content="Open Chrome Capture Setup"
                            Command="{Binding OpenChromeCaptureSetupCommand}"
                            MinWidth="184"
                            Margin="0,0,8,0" />
                    <Button Content="Open Chrome Extensions Page"
                            Command="{Binding OpenChromeExtensionsCommand}"
                            MinWidth="184" />
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
