<Window x:Class="MokoSnap.App.Views.OnboardingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Getting Started"
        MinHeight="500"
        MinWidth="620"
        Height="560"
        Width="680"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="18">
        <WrapPanel DockPanel.Dock="Bottom"
                   HorizontalAlignment="Right"
                   Margin="0,18,0,0">
            <Button Content="Open Chrome Capture Setup"
                    MinWidth="180"
                    Margin="0,0,8,8"
                    Click="OnOpenChromeCaptureSetupClicked" />
            <Button Content="Open Settings"
                    MinWidth="112"
                    Margin="0,0,8,8"
                    Click="OnOpenSettingsClicked" />
            <Button Content="Do not show again"
                    MinWidth="136"
                    Margin="0,0,8,8"
                    Click="OnDoNotShowAgainClicked" />
            <Button Content="Get Started"
                    MinWidth="112"
                    Margin="0,0,0,8"
                    IsDefault="True"
                    Click="OnGetStartedClicked" />
        </WrapPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Getting Started"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Text="MokoSnap switches your desktop work mode with presets. It can stay in the tray/background so your presets and hotkeys remain available." />

                <TextBlock Text="Tray / Background"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="When minimize to tray is enabled, minimizing or closing the main window hides MokoSnap to the tray instead of exiting." />

                <TextBlock Text="Quick Switcher"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="Press Ctrl+Alt+M to open the Quick Switcher by default. Type a preset name and press Enter to run it." />

                <TextBlock Text="Create Presets"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="Use Add to create a preset manually, or Capture Current Apps to add visible app targets from your current desktop." />

                <TextBlock Text="Run Presets"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="Run presets from the Run button, per-preset hotkeys, the tray menu, or the Quick Switcher." />

                <TextBlock Text="Chrome Capture"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="Chrome tab capture is optional and requires Chrome Capture Setup before importing captured tabs." />

                <TextBlock Text="Settings"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap"
                           Text="Open Settings to change hotkeys, startup registration, start minimized, and tray behavior." />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
