<ui:FluentWindow x:Class="MokoSnap.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:models="clr-namespace:MokoSnap.Core.Models;assembly=MokoSnap.Core"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="MokoSnap"
                 ExtendsContentIntoTitleBar="True"
                 MinHeight="720"
                 MinWidth="1080"
                 Height="760"
                 Width="1220">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="MokoSnap"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="False"
                               IsPaneOpen="True"
                               OpenPaneLength="220">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="Presets"
                                           Command="{Binding ShowPresetsSectionCommand}" />
                    <ui:NavigationViewItem Content="Settings"
                                           Command="{Binding ShowSettingsSectionCommand}" />
                    <ui:NavigationViewItem Content="Chrome Capture"
                                           Command="{Binding ShowChromeCaptureSectionCommand}" />
                    <ui:NavigationViewItem Content="Help"
                                           Command="{Binding ShowHelpSectionCommand}" />
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>

            <DockPanel Grid.Column="1" Margin="18">
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#D8DDE8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="3"
                                   Text="Status and Diagnostics"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Quick Switcher" FontWeight="SemiBold" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding QuickSwitcherStatusLabel}" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,3,0,3">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} - {1}">
                                    <Binding Path="QuickSwitcherHotkeySummary" />
                                    <Binding Path="QuickSwitcherHotkeyStatus" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Single instance" FontWeight="SemiBold" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SingleInstanceStatusLabel}" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SingleInstanceStatus}" Margin="0,3,0,3" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Tray" FontWeight="SemiBold" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TrayStatusLabel}" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding TrayStatus}" Margin="0,3,0,3" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Chrome native host" FontWeight="SemiBold" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ChromeNativeHostStatusLabel}" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ChromeNativeHostStatusText}" TextWrapping="Wrap" Margin="0,3,0,3" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Latest Chrome capture" FontWeight="SemiBold" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LatestChromeCaptureStatusLabel}" Margin="0,3,12,3" />
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding LatestChromeCaptureStatusText}" TextWrapping="Wrap" Margin="0,3,0,3" />

                        <Grid Grid.Row="6" Grid.ColumnSpan="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last operation" FontWeight="SemiBold" />
                                <TextBlock TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} - {1}">
                                            <Binding Path="LastOperationStatusLabel" />
                                            <Binding Path="LastOperationStatus" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="16,0,0,0">
                                <Button Content="Open Settings"
                                        Command="{Binding OpenSettingsCommand}"
                                        MinWidth="120"
                                        Margin="0,0,8,0" />
                                <Button Content="Chrome Capture Setup"
                                        Command="{Binding ChromeCaptureSetupCommand}"
                                        MinWidth="160"
                                        Margin="0,0,8,0" />
                                <Button Content="Import Latest Chrome Tabs"
                                        Command="{Binding ImportLatestChromeTabsCommand}"
                                        MinWidth="190" />
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
            <Grid Visibility="{Binding IsPresetsSectionSelected, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0">
                            <Button Content="Add Preset"
                                    Command="{Binding AddCommand}"
                                    MinWidth="110"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                            <Button Content="Save"
                                    Command="{Binding SaveCommand}"
                                    MinWidth="90"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                            <Button Content="Run Preset"
                                    Command="{Binding RunCommand}"
                                    MinWidth="120"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                            <Button Content="Capture Current Apps"
                                    Command="{Binding CaptureCurrentAppsCommand}"
                                    MinWidth="170"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                            <Button Content="Import Chrome Tabs"
                                    Command="{Binding ImportLatestChromeTabsCommand}"
                                    MinWidth="160"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                        </WrapPanel>

                        <Button Grid.Column="1"
                                Content="Delete Preset"
                                Command="{Binding DeleteCommand}"
                                MinWidth="120"
                                MinHeight="38"
                                Margin="12,0,0,8" />
                    </Grid>

                    <TextBlock DockPanel.Dock="Top"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Last operation: {0} - {1}">
                                <Binding Path="LastOperationStatusLabel" />
                                <Binding Path="LastOperationStatus" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Presets"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="No presets yet. Add a preset, then use Capture Current Apps or add targets manually."
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Presets.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ListBox ItemsSource="{Binding Presets}"
                                     SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                     DisplayMemberPath="Name" />
                        </DockPanel>

                        <Border Grid.Column="2"
                                BorderBrush="#D8DDE8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="18">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPreset}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="No preset selected"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Create a preset to define apps, URLs, folders, Chrome tabs, or Notion pages. You can also start by capturing currently visible apps."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />
                                <WrapPanel>
                                    <Button Content="Add Preset"
                                            Command="{Binding AddCommand}"
                                            MinWidth="120"
                                            MinHeight="38"
                                            Margin="0,0,8,8" />
                                    <Button Content="Chrome Capture Setup"
                                            Command="{Binding ChromeCaptureSetupCommand}"
                                            MinWidth="170"
                                            MinHeight="38"
                                            Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Column="2"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPreset}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <StackPanel>
                                <TextBlock Text="Selected Preset"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12" />
                                <Border BorderBrush="#D8DDE8"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="14"
                                        Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="0,0,12,10" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPreset.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" Margin="0,4,12,10" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPreset.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Close policy" Margin="0,0,12,10" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ClosePolicies}" SelectedItem="{Binding SelectedPreset.ClosePolicy, Mode=TwoWay}" Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="CloseVisibleWindowsOnly closes visible top-level user windows before launching targets. MokoSnap is excluded and confirmation rules still apply."
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPreset.ClosePolicy}" Value="{x:Static models:ClosePolicy.CloseVisibleWindowsOnly}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Close confirmation policy" Margin="0,0,12,10" />
                                    <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding CloseConfirmationPolicies}" SelectedItem="{Binding SelectedPreset.CloseConfirmationPolicy, Mode=TwoWay}" Margin="0,0,0,10" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Preset hotkey" Margin="0,0,12,0" />
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedPreset.HotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="OnHotkeyTextBoxPreviewKeyDown" />
                                </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <DockPanel Grid.Column="0">
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="Targets"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="Select a target to edit its details."
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />
                                        <WrapPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                            <Button Content="Add Target" Command="{Binding SelectedPreset.AddTargetCommand}" MinWidth="92" Margin="0,0,6,6" />
                                            <Button Content="Delete Target" Command="{Binding SelectedPreset.DeleteTargetCommand}" MinWidth="104" Margin="0,0,6,6" />
                                            <Button Content="Move Up" Command="{Binding SelectedPreset.MoveTargetUpCommand}" MinWidth="80" Margin="0,0,6,6" />
                                            <Button Content="Move Down" Command="{Binding SelectedPreset.MoveTargetDownCommand}" MinWidth="92" Margin="0,0,6,6" />
                                        </WrapPanel>
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Text="{Binding SelectedPreset.TargetEditorStatusMessage}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0" />
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Text="No targets yet. Use Capture Current Apps, Import Chrome Tabs, or Add Target. If Chrome import is unavailable, open Chrome Capture Setup first."
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPreset.Targets.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding SelectedPreset.Targets}"
                                                 SelectedItem="{Binding SelectedPreset.SelectedTarget, Mode=TwoWay}"
                                                 MinHeight="260">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8"
                                                            Margin="0,2">
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           Text="{Binding TypeLabel}"
                                                                           FontWeight="SemiBold"
                                                                           Margin="10,0,0,0" />
                                                                <TextBlock Text="{Binding DisplayTitle}"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding DetailSummary}"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,0,0,3" />
                                                            <TextBlock Text="{Binding MetadataSummary}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="12" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>

                                    <StackPanel Grid.Column="2" DataContext="{Binding SelectedPreset.SelectedTarget}">
                                        <TextBlock Text="Target Details"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,12" />
                                        <TextBlock Text="No target selected. Add a target, capture current apps, or import Chrome tabs to start editing."
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Display name" Margin="0,0,12,10" />
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Type" Margin="0,0,12,10" />
                                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DataContext.SelectedPreset.TargetTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Type, Mode=TwoWay}" Margin="0,0,0,10" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Launch delay ms" Margin="0,0,12,12" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LaunchDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                        </Grid>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsApplication}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Application" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Executable path" Margin="0,0,12,10" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Arguments" Margin="0,0,12,10" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Working directory" Margin="0,0,12,10" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <CheckBox Grid.Row="3" Grid.Column="1" Content="Run as admin" IsChecked="{Binding RunAsAdmin, Mode=TwoWay}" Margin="0,0,0,10" />
                                                <CheckBox Grid.Row="4" Grid.Column="1" Content="Remember window position" IsChecked="{Binding WindowPlacementEnabled, Mode=TwoWay}" Margin="0,0,0,10" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUrl}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="URL" Margin="0,0,12,10" />
                                                <TextBox Grid.Column="1" Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Path" Margin="0,0,12,10" />
                                                <TextBox Grid.Column="1" Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChrome}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Chrome" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile name" Margin="0,0,12,10" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <CheckBox Grid.Row="1" Grid.Column="1" Content="Open in new window" IsChecked="{Binding OpenInNewWindow, Mode=TwoWay}" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="URLs" Margin="0,4,12,10" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UrlsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="84" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNotion}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Notion" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Row="0" Grid.Column="1" Content="Prefer desktop app" IsChecked="{Binding PreferDesktopApp, Mode=TwoWay}" Margin="0,0,0,10" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Page URLs" Margin="0,4,12,0" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PageUrlsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="84" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Run result"
                                           FontWeight="SemiBold"
                                           Margin="0,18,0,8" />
                                <TextBox Text="{Binding RunResultMessage, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         MinHeight="72"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Grid>

            <StackPanel Visibility="{Binding IsSettingsSectionSelected, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Settings"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <TextBlock Text="Change hotkeys, startup, tray behavior, and Chrome Capture setup from this page. Save applies changes immediately; cancel reloads the last saved settings."
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="0,0,0,18" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SettingsPage}">
                        <TextBlock Text="General"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="Minimize to tray"
                                  IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="Start minimized to tray"
                                  IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}"
                                  Margin="0,0,0,18" />

                        <Separator Margin="0,0,0,16" />

                        <TextBlock Text="Quick Switcher Hotkey"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Quick Switcher"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding QuickSwitcherHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="OnHotkeyTextBoxPreviewKeyDown"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="2"
                                    Content="Reset"
                                    Command="{Binding ResetQuickSwitcherHotkeyCommand}" />
                        </Grid>
                        <TextBox Text="{Binding HotkeyValidationText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,18" />

                        <Separator Margin="0,0,0,16" />

                        <TextBlock Text="Startup / Tray"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="Launch MokoSnap when Windows starts"
                                  IsChecked="{Binding LaunchOnStartup, Mode=TwoWay}"
                                  Margin="0,0,0,10" />
                        <TextBox Text="{Binding StartupStatusText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="56"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,18" />

                        <Separator Margin="0,0,0,16" />

                        <TextBlock Text="Chrome Capture"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <TextBox Text="{Binding ChromeCaptureStatusText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="76"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10" />
                        <WrapPanel Margin="0,0,0,18">
                            <Button Content="Open Chrome Capture Setup"
                                    Command="{Binding OpenChromeCaptureSetupCommand}"
                                    MinWidth="190"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                            <Button Content="Open Chrome Extensions Page"
                                    Command="{Binding OpenChromeExtensionsCommand}"
                                    MinWidth="200"
                                    MinHeight="38"
                                    Margin="0,0,8,8" />
                        </WrapPanel>

                        <Separator Margin="0,0,0,16" />

                        <TextBlock Text="{Binding DataContext.SettingsPageStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <WrapPanel>
                            <Button Content="Save Settings"
                                    Command="{Binding DataContext.SaveSettingsPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    MinWidth="130"
                                    MinHeight="40"
                                    Margin="0,0,8,8" />
                            <Button Content="Cancel / Revert Changes"
                                    Command="{Binding DataContext.CancelSettingsPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    MinWidth="180"
                                    MinHeight="40"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Visibility="{Binding IsChromeCaptureSectionSelected, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Chrome Capture"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <TextBlock Text="Load the Chrome extension manually, paste the extension ID in Chrome Capture Setup, register the Native Host, restart Chrome if capture fails, then use Import Latest Chrome Tabs after capture."
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="0,0,0,16" />
                <WrapPanel Margin="0,0,0,16">
                    <Button Content="Chrome Capture Setup"
                            Command="{Binding ChromeCaptureSetupCommand}"
                            MinWidth="190"
                            MinHeight="40"
                            Margin="0,0,8,8" />
                    <Button Content="Import Latest Chrome Tabs"
                            Command="{Binding ImportLatestChromeTabsCommand}"
                            MinWidth="220"
                            MinHeight="40"
                            Margin="0,0,8,8" />
                </WrapPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Native host" FontWeight="SemiBold" Margin="0,3,12,6" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChromeNativeHostStatusLabel}" Margin="0,3,12,6" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ChromeNativeHostStatusText}" TextWrapping="Wrap" Margin="0,3,0,6" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Latest capture file" FontWeight="SemiBold" Margin="0,3,12,6" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LatestChromeCaptureStatusLabel}" Margin="0,3,12,6" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding LatestChromeCaptureStatusText}" TextWrapping="Wrap" Margin="0,3,0,6" />
                </Grid>
                <TextBox Text="{Binding ChromeCaptureStatus, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="100"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Visibility="{Binding IsHelpSectionSelected, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Help"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <WrapPanel Margin="0,0,0,18">
                    <Button Content="Getting Started"
                            Command="{Binding OpenGettingStartedCommand}"
                            MinWidth="160"
                            MinHeight="40"
                            Margin="0,0,8,8" />
                    <Button Content="Open Settings"
                            Command="{Binding OpenSettingsCommand}"
                            MinWidth="150"
                            MinHeight="40"
                            Margin="0,0,8,8" />
                    <Button Content="Chrome Capture Setup"
                            Command="{Binding ChromeCaptureSetupCommand}"
                            MinWidth="190"
                            MinHeight="40"
                            Margin="0,0,8,8" />
                </WrapPanel>
                <StackPanel>
                    <TextBlock Text="MokoSnap runs in the tray/background." TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock Text="Ctrl+Alt+M opens the Quick Switcher by default." TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock Text="X hides to tray when minimize-to-tray is enabled." TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock Text="Capture Current Apps creates Application targets from visible app windows." TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock Text="Chrome tab capture requires Chrome Capture Setup before importing tabs." TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock Text="Settings can change hotkeys, startup, and tray behavior." TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
                </Grid>
            </DockPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
